# Copy to .env and fill in. The app reads these on startup.

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown).
OPENAI_MODEL=gpt-4o-mini

# RAG / Retrieval Configuration
# Size of document chunks for embedding and retrieval
CHUNK_SIZE=512
# Overlap between chunks to preserve context
CHUNK_OVERLAP=50
# Number of chunks to retrieve for each question
TOP_K=3

# Text returned when an answer is not present in the document.
NOT_FOUND_TEXT=Data Not Available

# Limits
MAX_QUESTIONS=50
MAX_DOCUMENT_BYTES=33554432
